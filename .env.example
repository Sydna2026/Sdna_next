# Copy to ".env" (git-ignored) and fill in real values.
#   cp .env.example .env
# On the server, provision.sh creates a starter .env automatically if missing.

# --- Database (SQLite) -------------------------------------------------------
# Relative path is resolved next to prisma/schema.prisma => prisma/sdna.db
DATABASE_URL="file:./sdna.db"

# --- Public site URL (used to build links inside emails) ---------------------
APP_URL="https://sydan.org"

# --- Email (Resend) ----------------------------------------------------------
# Get a key at https://resend.com and verify the sydan.org sending domain.
# If left blank, emails are logged to the server console instead of sent.
RESEND_API_KEY=""
EMAIL_FROM="SDAN <news@sydan.org>"

# --- Article ingestion (Phase 3) --------------------------------------------
# Shared secret the server cron uses to trigger /api/cron/ingest.
# provision.sh generates one automatically on the server.
CRON_SECRET=""

# --- Admin: manage feeds now (Phase 3) / full panel (Phase 4) ----------------
# Set this to protect /api/admin/* and (later) the admin login. Blank = disabled.
ADMIN_PASSWORD=""
